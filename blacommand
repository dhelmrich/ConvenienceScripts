#!/bin/bash

SHELL_TYPE="bash"

if [ "$1" = "-t" ]; then
    if [ -z "$2" ]; then
        echo "Error: Shell type required after -t flag"
        echo "Usage: blacommand [-t bash|powershell|zsh] <your request>"
        exit 1
    fi
    SHELL_TYPE="$2"
    shift 2
fi

if [ -z "$1" ]; then
    echo "Usage: blacommand [-t bash|powershell|zsh] <your request>"
    echo "Example: blacommand please find log files"
    exit 1
fi

REQUEST="$*"
CONTEXT=""

case "$SHELL_TYPE" in
    bash)
        SYSTEM_PROMPT="You are a helpful assistant that only responds with a single bash command compatible with the present shell (bash). Do not include any explanation, markdown formatting, or additional text. Just the command itself."
        ;;
    powershell)
        SYSTEM_PROMPT="You are a helpful assistant that only responds with a single PowerShell command compatible with the present shell (powershell). Do not include any explanation, markdown formatting, or additional text. Just the command itself."
        ;;
    zsh)
        SYSTEM_PROMPT="You are a helpful assistant that only responds with a single zsh command compatible with the present shell (zsh). Do not include any explanation, markdown formatting, or additional text. Just the command itself."
        ;;
    *)
        echo "Error: Unsupported shell type: $SHELL_TYPE"
        echo "Supported types: bash, powershell, zsh"
        exit 1
        ;;
esac

echo "Asking alias-fast for a $SHELL_TYPE command..."
echo

while true; do
    CONTEXT_MSG=""
    if [ -n "$CONTEXT" ]; then
        CONTEXT_MSG="Previous failed attempts:\n$CONTEXT\n\n"
    fi
    
    RAW_RESPONSE=$(curl -s -X POST "https://api.blablador.fz-juelich.de/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $BLABLADOR_TOKEN" \
        -d "{
            \"model\": \"alias-fast\",
            \"messages\": [
                {
                    \"role\": \"system\",
                    \"content\": \"$SYSTEM_PROMPT\"
                },
                {
                    \"role\": \"user\",
                    \"content\": \"$CONTEXT_MSG$REQUEST\"
                }
            ],
            \"temperature\": 0.1
        }")
    
    COMMAND=$(echo "$RAW_RESPONSE" | jq -r '.choices[0].message.content' 2>/dev/null)
    
    if [ -z "$COMMAND" ] || [ "$COMMAND" = "null" ]; then
        echo "Error: Failed to get valid response from API"
        echo "Response: $RAW_RESPONSE"
        exit 1
    fi
    
    echo "Command returned:"
    echo
    echo "$COMMAND"
    echo
    echo "Press Ctrl+C to abort or Enter to run the command."
    read -r
    
    case "$SHELL_TYPE" in
        powershell)
            powershell -Command "$COMMAND" 2>&1 | tee /tmp/cmd_output; COMMAND_EXIT_CODE=$?
            ;;
        zsh)
            zsh -c "$COMMAND" 2>&1 | tee /tmp/cmd_output; COMMAND_EXIT_CODE=$?
            ;;
        *)
            eval "$COMMAND" 2>&1 | tee /tmp/cmd_output; COMMAND_EXIT_CODE=$?
            ;;
    esac
    
    COMMAND_OUTPUT=$(cat /tmp/cmd_output)
    rm -f /tmp/cmd_output
    
    echo
    if [ $COMMAND_EXIT_CODE -eq 0 ]; then
        break
    fi
    
    echo "Command failed with exit code $COMMAND_EXIT_CODE"
    echo "Output:"
    echo "$COMMAND_OUTPUT"
    echo
    
    CONTEXT+="Previous command (exit code $COMMAND_EXIT_CODE): $COMMAND\nOutput: $COMMAND_OUTPUT\n\n"
    
    echo "Type 'r' to retry with a different command, or Enter to exit:"
    read -r Retry
    
    if [ "$Retry" != "r" ]; then
        break
    fi
    
    echo
    echo "Asking alias-fast for another $SHELL_TYPE command..."
    echo
done
